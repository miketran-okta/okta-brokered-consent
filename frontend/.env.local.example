# ============================================================================
# Okta OIDC Configuration (for User Login)
# ============================================================================
# IMPORTANT: These credentials are for the OIDC Web Application that users
# log into. This is DIFFERENT from the AI Agent entity used for OAuth-STS.
#
# Get these from: Okta Admin Console → Applications → Your OIDC Web App
# ============================================================================

# OIDC Application Client ID (starts with '0oa')
# Found in: Okta Admin Console → Applications → Your OIDC App → General tab
OKTA_CLIENT_ID=0oaxxxxxxxxxxxxxxxx

# OIDC Application Client Secret
# Found in: Okta Admin Console → Applications → Your OIDC App → General tab
# Click "Copy to clipboard" next to the Client Secret field
OKTA_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Okta issuer URL (your Okta organization domain)
# Format: https://your-org.oktapreview.com
OKTA_ISSUER=https://your-org.oktapreview.com

# ============================================================================
# Public Okta Configuration (exposed to frontend)
# ============================================================================
# This is used for logout redirects and public-facing features
# Must match OKTA_ISSUER above
NEXT_PUBLIC_OKTA_DOMAIN=https://your-org.oktapreview.com
NEXT_PUBLIC_OKTA_CLIENT_ID=0oaxxxxxxxxxxxxxxxx
NEXT_PUBLIC_OKTA_ISSUER=https://your-org.oktapreview.com/

# ============================================================================
# Backend API Configuration
# ============================================================================
# URL of your FastAPI backend server
# Development: http://localhost:8000
# Production: https://your-backend.onrender.com (or your deployed backend URL)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================================
# NextAuth.js Configuration
# ============================================================================
# Your frontend application URL
# Development: http://localhost:3000
# Production: https://your-app.vercel.app (or your deployed frontend URL)
NEXTAUTH_URL=http://localhost:3000

# NextAuth secret for session encryption (REQUIRED)
# Generate a secure random string with: openssl rand -base64 32
# Keep this secret and never commit it to version control
# Example: Run this command in terminal:
#   openssl rand -base64 32
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file to .env.local:
#    cp .env.local.example .env.local
#
# 2. Fill in the values above with your actual credentials
#
# 3. Generate NEXTAUTH_SECRET:
#    openssl rand -base64 32
#
# 4. NEVER commit .env.local file to version control
#    (it's already in .gitignore)
#
# 5. For detailed setup instructions, see:
#    - README.md (Quick Start)
#    - docs/IMPLEMENTATION_SETUP_GUIDE.md (Detailed Setup)
#
# ============================================================================
# IMPORTANT NOTES
# ============================================================================
# - The OKTA_CLIENT_ID and OKTA_CLIENT_SECRET are for the OIDC application
#   that users log into (Client ID starts with '0oa')
#
# - This is DIFFERENT from the AI Agent entity used in the backend
#   (AI Agent ID starts with 'wlp')
#
# - The OIDC application must be "linked" to the AI Agent entity in Okta
#   Admin Console for OAuth-STS to work properly
#
# - Redirect URIs must be configured in the OIDC app:
#   * Sign-in redirect URI: http://localhost:3000/api/auth/callback/okta
#   * Sign-out redirect URI: http://localhost:3000
#
# ============================================================================
