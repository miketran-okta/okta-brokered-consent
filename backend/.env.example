# ============================================================================
# Okta Configuration
# ============================================================================
# Your Okta organization domain (e.g., https://your-org.oktapreview.com)
# Found in: Okta Admin Console → Top right corner
OKTA_DOMAIN=https://your-org.oktapreview.com

# Okta issuer URL (typically same as OKTA_DOMAIN)
OKTA_ISSUER=https://your-org.oktapreview.com

# ============================================================================
# AI Agent Configuration (OAuth-STS)
# ============================================================================
# AI Agent entity ID (starts with 'wlp')
# Found in: Okta Admin Console → Directory → AI Agents → Your Agent → Overview
OKTA_AI_AGENT_ID=wlpxxxxxxxxxxxxxxxxx

# Private JWK (JSON Web Key) for signing client assertions
# Obtained from: AI Agent → Generate public/private key pair → Download private key
# Format: JSON string with keys: kty, kid, use, alg, n, e, d, p, q, dp, dq, qi
# Example: {"kty":"RSA","kid":"abc123","use":"sig","alg":"RS256","n":"...","e":"AQAB","d":"...","p":"...","q":"...","dp":"...","dq":"...","qi":"..."}
OKTA_AI_AGENT_PRIVATE_KEY={"kty":"RSA","kid":"your-key-id","use":"sig","alg":"RS256","n":"your-modulus","e":"AQAB","d":"your-private-exponent","p":"your-prime1","q":"your-prime2","dp":"your-exponent1","dq":"your-exponent2","qi":"your-coefficient"}

# ============================================================================
# GitHub Resource Indicator (from Okta Managed Connection)
# ============================================================================
# Resource indicator for the GitHub managed connection
# Found in: AI Agent → Managed connections → GitHub connection → Resource indicator
# Format: ORN format (e.g., orn:oktapreview:idp:00xxxxx:client-auth-settings:rsxxxxx)
#     OR: Custom format (e.g., your-org:github:application)
OKTA_GITHUB_RESOURCE_INDICATOR=orn:oktapreview:idp:00xxxxxxxxxxxxx:client-auth-settings:rsxxxxxxxxxxxxx

# ============================================================================
# GitHub Configuration
# ============================================================================
# Your GitHub organization name or username
# Example: If your repos are under https://github.com/my-org, use "my-org"
GITHUB_ORG=your-github-org

# Default repository name for GitHub operations
# Used when user doesn't specify a repo in their request
GITHUB_DEFAULT_REPO=your-default-repo

# ============================================================================
# LiteLLM Proxy Configuration
# ============================================================================
# LiteLLM proxy API key for routing LLM requests
# Contact your LiteLLM proxy administrator for this key
LITELLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# LiteLLM proxy base URL
# Example: https://llm.atko.ai or your self-hosted proxy URL
LITELLM_BASE_URL=https://your-litellm-proxy.com

# LLM model to use for AI agent routing and response generation
# Options: claude-4-5-sonnet, claude-4-5-opus, gpt-4, etc.
# Default: claude-4-5-sonnet (recommended)
LITELLM_MODEL=claude-4-5-sonnet

# ============================================================================
# Server Configuration
# ============================================================================
# Port for the FastAPI backend server
BACKEND_PORT=8000

# Allowed CORS origins (comma-separated list)
# Add your frontend URL(s) here
# Example: http://localhost:3000,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# ============================================================================
# Debug & Logging
# ============================================================================
# Logging level - controls verbosity of logs
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Recommended: INFO for development, WARNING for production
LOG_LEVEL=INFO

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in all values above with your actual credentials
#
# 3. NEVER commit .env file to version control
#    (it's already in .gitignore)
#
# 4. For detailed setup instructions, see:
#    - README.md (Quick Start)
#    - docs/IMPLEMENTATION_SETUP_GUIDE.md (Detailed Setup)
#
# ============================================================================
