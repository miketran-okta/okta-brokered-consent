# Okta org — all OAuth endpoints are derived as {OKTA_DOMAIN}/oauth2/v1/*
OKTA_DOMAIN=https://your-org.oktapreview.com

# OIDC "linked application" (user login — Authorization Code + PKCE).
# The redirect URI must be registered on the Okta OIDC app.
OKTA_OIDC_CLIENT_ID=0oaxxxxxxxxxxxxxxxx
# Optional. Only needed if the OIDC app is a confidential client with a secret.
# Public/PKCE-only apps can leave this unset.
OKTA_OIDC_CLIENT_SECRET=
OKTA_OIDC_REDIRECT_URI=http://localhost:8765/callback
OKTA_OIDC_SCOPES=openid profile email

# AI Agent (OAuth-STS client) — same values the backend uses.
OKTA_AI_AGENT_ID=wlpxxxxxxxxxxxxxxxx
# Private JWK as a single-line JSON string. Must contain "d" (private exponent) and a "kid".
OKTA_AI_AGENT_PRIVATE_KEY={"kty":"RSA","kid":"...","n":"...","e":"AQAB","d":"...","p":"...","q":"...","dp":"...","dq":"...","qi":"..."}

# Resource indicator of the Okta Managed Connection for GitHub.
OKTA_GITHUB_RESOURCE_INDICATOR=https://github.com/...
